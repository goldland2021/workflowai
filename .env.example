# Copy this file to .env.local and fill in your values

# === 云端 DeepSeek（用户当前选择） ===
DEEPSEEK_API_KEY=sk-...

# === 云端 OpenAI（备选） ===
# OPENAI_API_KEY=sk-...

# === 本地大模型（隐私场景） ===
# Ollama 示例：
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=ollama

# LM Studio 示例：
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
# LLM_API_KEY=lm-studio

# 其他云端
# GROK_API_KEY=...
