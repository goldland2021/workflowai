# Copy this file to .env.local and fill in your values

# === 数据库（必需：注册/登录、公司数据都存在这里） ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 签名登录 session 的密钥，生产环境请设置为一个随机字符串
# SESSION_SECRET=change-me-in-production

# Optional separate signing secret for public Widget tokens.
# WIDGET_TOKEN_SECRET=change-me-in-production

# Optional webhook that receives password-reset and email-verification links.
# AUTH_EMAIL_WEBHOOK_URL=https://your-email-service.example.com/auth-email
# Or use Resend directly (the webhook takes precedence when both are set).
# RESEND_API_KEY=re_...
# AUTH_EMAIL_FROM=WorkflowAI <auth@your-domain.example>

# === Stripe Billing（测试模式先使用 sk_test_ 和 price_ 测试价格） ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_GROWTH_PRICE_ID=price_...
# APP_URL=http://localhost:3000

# === 云端 DeepSeek（用户当前选择） ===
DEEPSEEK_API_KEY=sk-...

# === 航班到达查询（可选，服务器端使用） ===
# FlightAware AeroAPI v4. Without this key, WorkflowAI will not guess terminals.
# FLIGHT_DATA_API_KEY=...
# FLIGHT_DATA_BASE_URL=https://aeroapi.flightaware.com/aeroapi

# Google Maps server-side route enrichment for distance, drive time, and Tokyo toll zones.
# Restrict this key to Geocoding API, Routes API, Directions API, and Places API (New).
# GOOGLE_MAPS_SERVER_API_KEY=...

# === 云端 OpenAI（备选） ===
# OPENAI_API_KEY=sk-...

# === 本地大模型（隐私场景） ===
# Ollama 示例：
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=ollama

# LM Studio 示例：
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
# LLM_API_KEY=lm-studio

# 其他云端
# GROK_API_KEY=...

# === 对话引擎重构（Phase 1/4）===
# 单次编排调用开关。默认关闭，开启后走 orchestrate.ts 的单次结构化调用，
# 失败自动回退到旧的多次调用路径。灰度时先在预发/单公司开启验证。
# AI_ORCHESTRATOR_ENABLED=true
#
# 分角色模型（都留空时回退到 LLM_MODEL，行为不变）：
# 编排+回复用强模型（多语言推理与措辞质量更好），例如 deepseek-chat / gpt-4o / claude 兼容端点
# LLM_MODEL_ORCHESTRATOR=
# 结构化抽取可用更便宜的模型
# LLM_MODEL_EXTRACT=
